{
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "claude-obsidian-save"
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "claude-notify 'Claude Code' '作業が完了しました'"
        },
        {
          "type": "command",
          "command": "claude-obsidian-save"
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "claude-obsidian-save",
          "timeout": 120
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "matcher": "Bash",
      "hooks": [
        {
          "type": "command",
          "command": "claude-obsidian-save"
        }
      ]
    },
    {
      "matcher": "EnterPlanMode",
      "hooks": [
        {
          "type": "command",
          "command": "claude-obsidian-save"
        }
      ]
    },
    {
      "matcher": "ExitPlanMode",
      "hooks": [
        {
          "type": "command",
          "command": "claude-obsidian-save"
        }
      ]
    },
    {
      "matcher": "Edit",
      "hooks": [
        {
          "type": "command",
          "command": "claude-obsidian-save"
        }
      ]
    },
    {
      "matcher": "Write",
      "hooks": [
        {
          "type": "command",
          "command": "claude-obsidian-save"
        }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "claude-notify 'Claude Code' 'パーミッションが必要です'"
        }
      ]
    }
  ],
  "Notification": [
    {
      "matcher": "permission_prompt",
      "hooks": [
        {
          "type": "command",
          "command": "claude-notify 'Claude Code' 'ユーザー確認が必要です'"
        }
      ]
    },
    {
      "matcher": "idle_prompt",
      "hooks": [
        {
          "type": "command",
          "command": "claude-notify 'Claude Code' '待機中です'"
        }
      ]
    }
  ]
}
