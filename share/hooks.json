{
  "UserPromptSubmit": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "claude-code-hooks save"
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "claude-code-hooks notify 'Claude Code' '作業が完了しました'"
        },
        {
          "type": "command",
          "command": "claude-code-hooks save"
        }
      ]
    }
  ],
  "SessionEnd": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "claude-code-hooks save",
          "timeout": 120,
          "statusMessage": "Obsidian にセッションを保存中..."
        },
        {
          "type": "command",
          "command": "claude-code-hooks notify 'Claude Code' 'セッションの保存が完了しました'"
        }
      ]
    }
  ],
  "PostToolUse": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "claude-code-hooks save"
        }
      ]
    }
  ],
  "PermissionRequest": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "claude-code-hooks notify 'Claude Code' 'パーミッションが必要です'"
        }
      ]
    }
  ],
  "Notification": [
    {
      "matcher": "permission_prompt",
      "hooks": [
        {
          "type": "command",
          "command": "claude-code-hooks notify 'Claude Code' 'ユーザー確認が必要です'"
        }
      ]
    },
    {
      "matcher": "idle_prompt",
      "hooks": [
        {
          "type": "command",
          "command": "claude-code-hooks notify 'Claude Code' '待機中です'"
        }
      ]
    }
  ]
}
